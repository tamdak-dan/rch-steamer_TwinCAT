></DataType><DataType><Name>TwinCAT_PreventOnlineChangeGvl</Name><SubItem><Name Static="true">WriteLineIDs</Name><Type>BOOL</Type><BitSize>8</BitSize><Default><Bool>false</Bool></Default></SubItem><SubItem><Name Static="true">PlcProfilerActive</Name><Type>BOOL</Type><BitSize>8</BitSize><Default><Bool>false</Bool></Default></SubItem><SubItem><Name Static="true">PlcProfilerConfigChecksum</Name><Type>STRING(64)</Type><BitSize>520</BitSize><Default><String /></Default></SubItem><Properties><Property><Name>linkalways</Name></Property></Properties></DataType><DataType><Name>GVL_IO</Name><SubItem><Name Static="true">nTempSensor</Name><Type>INT</Type><BitSize>16</BitSize><Properties><Property><Name>TcDataArea</Name><Value>Input</Value></Property></Properties></SubItem><Properties><Property><Name>qualified_only</Name></Property></Properties></DataType><DataType><Name>GVL_HMI</Name><Comment><![CDATA[=============================================================================
 GVL_HMI
-----------------------------------------------------------------------------
 The ONLY variables the RPi/pyads client touches. Three symbols, three jobs:

   GVL_HMI.stStatus           PLC -> Pi   read-only  (one bulk read per poll)
   GVL_HMI.stCommand          Pi -> PLC   buttons + heartbeat
   GVL_HMI.stSetpointRequest  Pi -> PLC   config values, applied via
                                          stCommand.bApplySetpoints

 Everything else in the PLC is off-limits to the HMI by convention.
 If the HMI needs a new value, add it to ST_HmiStatus — never let the
 Pi read internal FB state directly, or the interface contract rots.

 pyads access, e.g.:
   plc = pyads.Connection('5.x.x.x.1.1', 851)
   status = plc.read_by_name('GVL_HMI.stStatus', structure_def=HMI_STATUS_DEF)
   plc.write_by_name('GVL_HMI.stCommand.bSesOn', True)
=============================================================================]]></Comment><SubItem><Name Static="true">stStatus</Name><Type>ST_HmiStatus</Type><Comment><![CDATA[ PLC -> Pi]]></Comment><BitSize>1936</BitSize></SubItem><SubItem><Name Static="true">stCommand</Name><Type>ST_HmiCommand</Type><Comment><![CDATA[ Pi -> PLC (FB_Hmi consumes+clears pulses)]]></Comment><BitSize>160</BitSize></SubItem><SubItem><Name Static="true">stSetpointRequest</Name><Type>ST_HmiSetpoints</Type><Comment><![CDATA[ Pi -> PLC (applied on bApplySetpoints)]]></Comment><BitSize>96</BitSize></SubItem><SubItem><Name Static="true">T_HMI_HEARTBEAT_TIMEOUT</Name><Type>TIME</Type><Comment><![CDATA[ Pi poll rate is expected >= 1 Hz; comm loss declared after this timeout]]></Comment><BitSize>32</BitSize><Default><DateTime>T#5S</DateTime></Default></SubItem><SubItem><Name Static="true">S_PLC_VERSION</Name><Type>STRING(31)</Type><BitSize>256</BitSize><Default><String>V 0.x</String></Default></SubItem><Properties><Property><Name>qualified_only</Name></Property></Properties></DataType></DataTypes><Modules><Module GUID="{41E0896A-0BBF-4909-9762-2A52B81D9898}" TcSmClass="TComPlcObjDef" TargetPlatform="TwinCAT OS (ARMV7-M)"><Name>Steamer</Name><CLSID ClassFactory="TcPlc30">{08500001-0000-0000-F000-000000000064}</CLSID><Licenses /><Contexts><Context><Id NeedCalleeCall="true">0</Id><Name>PlcTask</Name><ManualConfig><OTCID>#x02010030</OTCID></ManualConfig></Context></Contexts><Parameters><Parameter ReadOnly="True"><Name>DeviceLog Filter</Name><BaseType>UDINT</BaseType><PTCID>#x08508045</PTCID></Parameter></Parameters><ParameterValues><Value><Name>DeviceLog Filter</Name><Data>00000000</Data></Value></ParameterValues><DataAreas><DataArea><AreaNo AreaType="InputDst" CreateSymbols="true">0</AreaNo><Name>PlcTask Inputs</Name><ContextId>0</ContextId><ByteSize>2097152</ByteSize><Symbol><Name>GVL_IO.nTempSensor</Name><BitSize>16</BitSize><BaseType>INT</BaseType><Properties><Property><Name>TcVarGlobal</Name>