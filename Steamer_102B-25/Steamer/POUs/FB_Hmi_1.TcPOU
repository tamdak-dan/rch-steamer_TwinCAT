<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FB_Hmi_1" Id="{a1b2c3d4-0009-4a5b-9c8d-e1f200000009}" SpecialFunc="None">
    <Declaration><![CDATA[//=============================================================================
// FB_Hmi
//-----------------------------------------------------------------------------
// Single point of contact between the PLC application and GVL_HMI.
// Responsibilities:
//   1. Publish ST_HmiStatus from process data every cycle.
//   2. Consume command pulses from ST_HmiCommand (consume-on-read: latch
//      to outputs for one cycle, then clear the GVL bit).
//   3. Gate maintenance overrides so they only pass through in Maintenance.
//   4. Validate + clamp setpoint requests; echo applied values.
//   5. Supervise the Pi heartbeat -> bHmiCommLoss.
//
// Call once per cycle from MAIN, after process data is updated and before
// FB_StateMachine (so commands take effect same-cycle):
//
//   fbHmi(eState        := fbStateMachine.eState,
//         stProcess     := GVL_Process.stValues,
//         stFaults      := fbFaultMonitor.stFaults,
//         bReady        := fbStateMachine.bReady,
//         arPidOutput   := fbPressureControl.arOutputPct);
//
//   IF fbHmi.bCmdSesOn      THEN fbStateMachine.RequestStart();  END_IF
//   IF fbHmi.bCmdSesOff     THEN fbStateMachine.RequestStop();   END_IF
//   IF fbHmi.bCmdFaultReset THEN fbFaultMonitor.ResetAll();      END_IF
//=============================================================================
FUNCTION_BLOCK FB_Hmi
VAR_INPUT
    eState          : E_SystemState;
    stProcess       : ST_ProcessValues;
    stFaults        : ST_Faults;              // from FB_FaultMonitor
    bReady          : BOOL;                   // temps in band, ok to flow
    arPidOutput     : ARRAY[1..6] OF REAL;    // loop outputs 0..100 %
    arValveActual   : ARRAY[1..4] OF BOOL;    // real valve output states
    stLimits        : ST_SetpointLimits;      // clamp ranges (defaults ok)
END_VAR
VAR_OUTPUT
    // one-cycle command pulses for MAIN / state machine
    bCmdSesOn       : BOOL;
    bCmdSesOff      : BOOL;
    bCmdFaultReset  : BOOL;
    bCmdFaultAck    : BOOL;
    bCmdEnterMaint  : BOOL;
    bCmdExitMaint   : BOOL;
    bSetpointsChanged : BOOL;                 // one-cycle pulse on accepted apply

    // validated, clamped setpoints (stable levels, safe to feed PIDs)
    stSetpoints     : ST_HmiSetpoints;

    // maintenance overrides — all forced FALSE outside Maintenance state
    arValveOverride : ARRAY[1..4] OF BOOL;
    bLoopbackOn     : BOOL;
    bDrainMode      : BOOL;
    bDpControlOff   : BOOL;
    bTempControlOff : BOOL;
    bExtHeaterEnable: BOOL;

    bHmiCommLoss    : BOOL;                   // feed into ST_Faults.bHmiCommLoss
END_VAR
VAR
    // heartbeat supervision
    nLastHeartbeat  : UDINT;
    tonHbTimeout    : TON;
    bFirstCycle     : BOOL := TRUE;

    // uptime
    tonUptime       : TON;
    nUptimeSeconds  : UDINT;
    fbTick          : TON;

    i               : INT;
    nFaultCount     : UINT;
    pFaultByte      : POINTER TO BYTE;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[//=========================== 1. Heartbeat supervision =========================
// Pi increments stCommand.nHmiHeartbeat every poll. If it stops changing
// for T_HMI_HEARTBEAT_TIMEOUT, declare comm loss.
tonHbTimeout(IN := (GVL_HMI.stCommand.nHmiHeartbeat = nLastHeartbeat) AND NOT bFirstCycle,
             PT := GVL_HMI.T_HMI_HEARTBEAT_TIMEOUT);
bHmiCommLoss := tonHbTimeout.Q;
nLastHeartbeat := GVL_HMI.stCommand.nHmiHeartbeat;
bFirstCycle := FALSE;

//=========================== 2. Consume command pulses ========================
// Latch each request to the output for exactly one cycle, then clear the
// GVL bit so the Pi never has to write FALSE and a stuck TRUE cannot
// repeat-fire.
bCmdSesOn      := GVL_HMI.stCommand.bSesOn;
bCmdSesOff     := GVL_HMI.stCommand.bSesOff;
bCmdFaultReset := GVL_HMI.stCommand.bFaultReset;
bCmdFaultAck   := GVL_HMI.stCommand.bFaultAck;
bCmdEnterMaint := GVL_HMI.stCommand.bEnterMaint;
bCmdExitMaint  := GVL_HMI.stCommand.bExitMaint;

GVL_HMI.stCommand.bSesOn      := FALSE;
GVL_HMI.stCommand.bSesOff     := FALSE;
GVL_HMI.stCommand.bFaultReset := FALSE;
GVL_HMI.stCommand.bFaultAck   := FALSE;
GVL_HMI.stCommand.bEnterMaint := FALSE;
GVL_HMI.stCommand.bExitMaint  := FALSE;

// Safety interlock: ignore SES ON during comm-lost or active fault display;
// the state machine makes the final call, this is belt-and-braces.
IF bHmiCommLoss THEN
    bCmdSesOn := FALSE;
END_IF

//=========================== 3. Maintenance overrides =========================
// Levels (not pulses) — pass through only while in Maintenance state.
IF eState = E_SystemState.Maintenance THEN
    FOR i := 1 TO 4 DO
        arValveOverride[i] := GVL_HMI.stCommand.aValveCmd[i];
    END_FOR
    bLoopbackOn      := GVL_HMI.stCommand.bLoopbackOn;
    bDrainMode       := GVL_HMI.stCommand.bDrainMode;
    bDpControlOff    := GVL_HMI.stCommand.bDpControlOff;
    bTempControlOff  := GVL_HMI.stCommand.bTempControlOff;
ELSE
    // leaving (or not in) maintenance: overrides off, and scrub the
    // requests in the GVL so nothing is pre-armed for next entry
    FOR i := 1 TO 4 DO
        arValveOverride[i] := FALSE;
        GVL_HMI.stCommand.aValveCmd[i] := FALSE;
    END_FOR
    bLoopbackOn      := FALSE;
    bDrainMode       := FALSE;
    bDpControlOff    := FALSE;
    bTempControlOff  := FALSE;
    GVL_HMI.stCommand.bLoopbackOn     := FALSE;
    GVL_HMI.stCommand.bDrainMode      := FALSE;
    GVL_HMI.stCommand.bDpControlOff   := FALSE;
    GVL_HMI.stCommand.bTempControlOff := FALSE;
END_IF
// heater enable is allowed in any state (config-level, not maintenance-only)
bExtHeaterEnable := GVL_HMI.stCommand.bExtHeaterEnable;

//=========================== 4. Setpoint apply + clamp ========================
bSetpointsChanged := FALSE;
IF GVL_HMI.stCommand.bApplySetpoints THEN
    GVL_HMI.stCommand.bApplySetpoints := FALSE;

    stSetpoints.rSetFlow       := LIMIT(stLimits.rFlowMin,
                                        GVL_HMI.stSetpointRequest.rSetFlow,
                                        stLimits.rFlowMax);
    stSetpoints.rSetDsPressure := LIMIT(stLimits.rDsPressMin,
                                        GVL_HMI.stSetpointRequest.rSetDsPressure,
                                        stLimits.rDsPressMax);
    stSetpoints.rSetSpaTemp    := LIMIT(stLimits.rSpaTempMin,
                                        GVL_HMI.stSetpointRequest.rSetSpaTemp,
                                        stLimits.rSpaTempMax);
    bSetpointsChanged := TRUE;
END_IF

//=========================== 5. Publish status ================================
GVL_HMI.stStatus.nPlcHeartbeat     := GVL_HMI.stStatus.nPlcHeartbeat + 1;
GVL_HMI.stStatus.nHmiHeartbeatEcho := GVL_HMI.stCommand.nHmiHeartbeat;
GVL_HMI.stStatus.bHmiOnline        := NOT bHmiCommLoss;

GVL_HMI.stStatus.eState       := eState;
GVL_HMI.stStatus.sStateName   := TO_STRING(eState);
GVL_HMI.stStatus.bReady       := bReady;

GVL_HMI.stStatus.stProcess    := stProcess;
IF stProcess.rFlowRated > 0.0 THEN
    GVL_HMI.stStatus.rFlowPercent := 100.0 * stProcess.rFlowActual / stProcess.rFlowRated;
ELSE
    GVL_HMI.stStatus.rFlowPercent := 0.0;
END_IF

FOR i := 1 TO 6 DO
    GVL_HMI.stStatus.arPidOutput[i] := arPidOutput[i];
END_FOR

GVL_HMI.stStatus.stFaults := stFaults;
GVL_HMI.stStatus.stFaults.bHmiCommLoss := bHmiCommLoss;

// count active fault bytes (pack_mode 1: one BOOL per byte)
nFaultCount := 0;
pFaultByte := ADR(GVL_HMI.stStatus.stFaults);
FOR i := 0 TO TO_INT(SIZEOF(ST_Faults)) - 1 DO
    IF pFaultByte[i] <> 0 THEN
        nFaultCount := nFaultCount + 1;
    END_IF
END_FOR
GVL_HMI.stStatus.nActiveFaults := nFaultCount;
GVL_HMI.stStatus.bAlarmActive  := (nFaultCount > 0);

GVL_HMI.stStatus.rSetFlowApplied    := stSetpoints.rSetFlow;
GVL_HMI.stStatus.rSetDsPressApplied := stSetpoints.rSetDsPressure;
GVL_HMI.stStatus.rSetSpaTempApplied := stSetpoints.rSetSpaTemp;

GVL_HMI.stStatus.bMaintModeActive := (eState = E_SystemState.Maintenance);
FOR i := 1 TO 4 DO
    GVL_HMI.stStatus.arValveState[i] := arValveActual[i];
END_FOR
GVL_HMI.stStatus.bLoopbackOn  := bLoopbackOn;
GVL_HMI.stStatus.bDrainModeOn := bDrainMode;

GVL_HMI.stStatus.sPlcVersion := GVL_HMI.S_PLC_VERSION;

// uptime counter (1 s self-retriggering tick)
fbTick(IN := NOT fbTick.Q, PT := T#1S);
IF fbTick.Q THEN
    nUptimeSeconds := nUptimeSeconds + 1;
END_IF
GVL_HMI.stStatus.nUptimeSeconds := nUptimeSeconds;
]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>